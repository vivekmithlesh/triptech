// Rename to sentry.server.config.ts after `npm i @sentry/nextjs`.
// See docs/SENTRY_SETUP.md.
import * as Sentry from "@sentry/nextjs";

Sentry.init({
  dsn: process.env.SENTRY_DSN,
  environment: process.env.SENTRY_ENVIRONMENT ?? process.env.NODE_ENV,
  tracesSampleRate: 0.1,
  // Don't send PII; we attach our own structured context via reportError.
  sendDefaultPii: false,
});

// Let src/lib/observability.ts forward to Sentry without a static import.
(globalThis as unknown as { __roamioSentry: typeof Sentry }).__roamioSentry = Sentry;
